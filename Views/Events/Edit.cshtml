@model HTicket.Models.Event

@{
    ViewData["Title"] = "Chỉnh sửa sự kiện";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Chỉnh sửa thông tin sự kiện</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Name" class="form-label font-weight-bold">Tên sự kiện</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sự kiện..." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EventDate" class="form-label font-weight-bold">Ngày diễn ra</label>
                        <input asp-for="EventDate" class="form-control" />
                        <span asp-validation-for="EventDate" class="text-danger"></span>
                    </div>

                    <div class="col-12 mb-3">
                        <label asp-for="Description" class="form-label font-weight-bold">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Location" class="form-label font-weight-bold">Địa điểm</label>
                        <input asp-for="Location" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Category" class="form-label font-weight-bold">Danh mục</label>
                        <select asp-for="Category" class="form-select">
                            <option value="Nhạc">Âm nhạc / Concert</option>
                            <option value="Sân khấu">Kịch / Sân khấu</option>
                            <option value="Thể thao">Thể thao</option>
                            <option value="Hội thảo">Hội thảo / Giáo dục</option>
                        </select>
                    </div>

                    <div class="col-md-6 mb-4">
                        <label asp-for="Status" class="form-label font-weight-bold">Trạng thái hiện tại</label>
                        <select asp-for="Status" class="form-select border-primary">
                            <option value="Đang mở bán">🎟️ Đang mở bán</option>
                            <option value="Sắp diễn ra">🔥 Sắp diễn ra</option>
                            <option value="Đã kết thúc">✅ Đã kết thúc</option>
                            <option value="Đã hủy">❌ Đã hủy</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Lưu thay đổi</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>