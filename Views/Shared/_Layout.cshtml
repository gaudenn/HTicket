<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Bán Vé</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
</head>
<body>
    @Html.AntiForgeryToken()

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">H-TICKET</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">🏠 Trang chủ</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        ⚙️ Quản lý hệ thống
                                    </a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" asp-controller="Events" asp-action="Index">📅 Sự kiện</a></li>
                                        <li><a class="dropdown-item" asp-controller="Tickets" asp-action="Index">🎟️ Loại Vé</a></li>
                                        <li><a class="dropdown-item" asp-controller="Customers" asp-action="Index">👥 Khách hàng</a></li>
                                        <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">🛒 Đơn hàng</a></li>
                                        <li><a class="dropdown-item" asp-controller="Statistics" asp-action="Index">📊 Thống kê</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item fw-bold text-primary" asp-controller="AI" asp-action="Index">📈 AI Dự báo nhu cầu</a></li>
                                    </ul>
                                </li>
                            }
                            else if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="Orders" asp-action="Create">🎟️ Đặt vé</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="Orders" asp-action="Index">🛒 Đơn hàng của tôi</a></li>
                                <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Profile">👥 Thông tin cá nhân</a></li>
                            }
                        }
                    </ul>

                    <div class="navbar-nav align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <span class="nav-link text-dark me-2">Xin chào, <b>@User.Identity.Name</b></span>
                            <a class="btn btn-outline-danger rounded-pill" asp-controller="Account" asp-action="Logout" onclick="sessionStorage.clear();">Đăng xuất</a>
                        }
                        else
                        {
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3 me-2" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            <a class="btn btn-primary btn-sm rounded-pill px-4" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

