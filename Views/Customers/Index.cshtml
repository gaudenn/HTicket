@model IEnumerable<HTicket.Models.Customer>


<div class="container-fluid mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-people-fill"></i> Quản lý Khách hàng</h4>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <form asp-action="Index" method="get" class="d-flex gap-2 w-50">
                    <input type="text" name="searchString" class="form-control" placeholder="Tìm tên, email hoặc SĐT..." value="@Context.Request.Query["searchString"]">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
                </form>
                <a asp-action="Create" class="btn btn-primary">Thêm khách hàng mới</a>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%">Họ và Tên</th>
                        <th style="width: 30%">Email</th>
                        <th style="width: 20%">Số điện thoại</th>
                        <th style="width: 25%" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.PhoneNumber</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>